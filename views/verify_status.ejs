<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= success ? 'Status Confirmed' : 'Status Update' %> — MyLibrary</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"/>
  <link rel="stylesheet" href="/css/auth.css"/>
  <style>
    .verify-status-icon {
      width: 76px;
      height: 76px;
      border-radius: 22px;
      margin: 0 auto 22px;
      display: grid;
      place-items: center;
      box-shadow: 0 18px 30px rgba(13,27,42,0.18);
      color: #fff;
    }
    .verify-status-icon.is-success {
      background: linear-gradient(135deg, #16a34a, #22c55e);
    }
    .verify-status-icon.is-error {
      background: linear-gradient(135deg, #991b1b, #dc2626);
    }
  </style>
</head>
<body>
  <div class="auth-split">
    <div class="auth-panel">
      <div class="auth-panel-content">
        <div class="auth-logo">
          <div class="auth-logo-icon"><i class="fa-solid fa-book-open"></i></div>
          <div>
            <span class="auth-logo-text">MyLibrary</span>
            <span class="auth-logo-sub">Digital Collection</span>
          </div>
        </div>

        <h2 class="auth-panel-headline">
          <%= success ? 'Everything\'s' : 'A quick' %><br/>
          <em><%= success ? 'Working' : 'Status' %></em><br/>
          <%= success ? 'as expected.' : 'update.' %>
        </h2>

        <p class="auth-panel-text">
          <%= success
            ? 'Your request was completed successfully. Use the links on the right to continue.'
            : 'Something needs your attention. Review the message on the right and continue from there.' %>
        </p>
      </div>

      <div class="auth-panel-footer">
        <div class="auth-stat">
          <i class="fa-solid <%= success ? 'fa-circle-check' : 'fa-triangle-exclamation' %> auth-stat-icon"></i>
          <div>
            <div class="auth-stat-num"><%= success ? 'Done' : 'Notice' %></div>
            <div class="auth-stat-label"><%= success ? 'Request processed successfully' : 'Action may be required' %></div>
          </div>
        </div>
      </div>
    </div>

    <div class="auth-form-panel">
      <div class="auth-form-wrap" style="text-align:center;">
        <div class="verify-status-icon <%= success ? 'is-success' : 'is-error' %>">
          <i class="fa-solid <%= success ? 'fa-circle-check' : 'fa-circle-exclamation' %>" style="font-size:34px;"></i>
        </div>

        <h1 class="auth-heading" style="margin-bottom:12px;">Status Update</h1>
        <p class="auth-sub" style="margin-bottom:18px;"><%= message %></p>

        <div class="msg-<%= success ? 'success' : 'error' %>" style="justify-content:center;text-align:left;margin-bottom:22px;">
          <i class="fa-solid <%= success ? 'fa-circle-check' : 'fa-circle-exclamation' %>"></i>
          <span><%= message %></span>
        </div>

        <div class="auth-links" style="margin-top:0; gap:10px;">
          <% if (success) { %>
            <a href="/login" class="btn-auth" style="text-decoration:none;">Go to Login</a>
            <a href="/dashboard" class="auth-link-line" style="display:block;">Back to Dashboard</a>
          <% } else { %>
            <a href="/signup" class="btn-auth" style="text-decoration:none;">Create Account</a>
            <a href="/login" class="auth-link-line" style="display:block;">Back to Login</a>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</body>
</html>