<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Forgot Password — MyLibrary</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"/>
  <link rel="stylesheet" href="/css/auth.css"/>
</head>
<body>
  <div class="auth-split">

    <!-- Left panel -->
    <div class="auth-panel">
      <div class="auth-panel-content">
        <div class="auth-logo">
          <div class="auth-logo-icon"><i class="fa-solid fa-book-open"></i></div>
          <div>
            <span class="auth-logo-text">MyLibrary</span>
            <span class="auth-logo-sub">Digital Collection</span>
          </div>
        </div>
        <h2 class="auth-panel-headline">
          Reset Your<br/><em>Password</em><br/>Securely.
        </h2>
        <p class="auth-panel-text">
          We'll send a password reset link to your registered email address. It only takes a moment.
        </p>
      </div>
      <div class="auth-panel-footer">
        <div class="auth-stat">
          <i class="fa-solid fa-shield-halved auth-stat-icon"></i>
          <div>
            <div class="auth-stat-num">Secure</div>
            <div class="auth-stat-label">Encrypted reset links</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Right panel -->
    <div class="auth-form-panel">
      <div class="auth-form-wrap">
        <a href="/login" class="auth-back">
          <i class="fa-solid fa-arrow-left"></i>
          Back to Login
        </a>

        <h1 class="auth-heading">Forgot Password?</h1>
        <p class="auth-sub">Enter your email and we'll send you a reset link.</p>

        <% if (typeof message !== 'undefined' && message) { %>
          <div class="<%= typeof type !== 'undefined' && type === 'success' ? 'msg-success' : 'msg-error' %>">
            <i class="fa-solid fa-<%= typeof type !== 'undefined' && type === 'success' ? 'circle-check' : 'circle-exclamation' %>"></i>
            <%= message %>
          </div>
        <% } %>

        <form action="/forgot-password" method="POST">
          <div class="form-group">
            <label class="form-label" for="email">Email Address</label>
            <div class="input-wrap">
              <i class="fa-solid fa-envelope icon-left"></i>
              <input
                class="form-input no-right-icon"
                type="email"
                id="email"
                name="email"
                placeholder="Enter your registered email"
                required
                autocomplete="email"
              />
            </div>
          </div>

          <button type="submit" class="btn-auth">
            <i class="fa-solid fa-paper-plane"></i>
            Send Reset Link
          </button>
        </form>

        <div class="auth-links">
          <div class="auth-link-line">
            Remembered it? <a href="/login">Sign in instead</a>
          </div>
        </div>
      </div>
    </div>

  </div>
</body>
</html>
