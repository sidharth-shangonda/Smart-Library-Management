<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Admin Login — MyLibrary</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"/>
  <link rel="stylesheet" href="/css/auth.css"/>
  <style>
    /* Admin-specific overrides */
    .log_in { height: 480px; border-color: #f0c040; }
    .admin-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(255,193,7,0.18);
      border: 1px solid #f0c040;
      color: #f0c040;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
      padding: 4px 12px;
      border-radius: 20px;
      margin-bottom: 6px;
    }
    .log_in h1 { color: #f0c040; margin-top: 10px; }
    .input-box input { border-color: #f0c040; color: #183153; }
    .input-box > i { color: #b8960c; }
    .pass i { color: #b8960c; }
    .btn-admin {
      width: 100%;
      height: 42px;
      background: #b8960c;
      color: white;
      border: none;
      border-radius: 10px;
      font-size: 16px;
      font-weight: 600;
      margin-top: 20px;
      cursor: pointer;
      letter-spacing: 0.5px;
      transition: background 0.2s;
    }
    .btn-admin:hover { background: #9a7d0a; }
    .user-login-link {
      margin-top: 14px;
      font-size: 13px;
      color: rgba(255,255,255,0.7);
      text-align: center;
    }
    .user-login-link a { color: wheat; text-decoration: none; font-weight: 600; }
    .user-login-link a:hover { text-decoration: underline; }
  </style>
  <link rel="stylesheet" href="/css/mobile-responsive.css"/>
</head>
<body>
  <div class="log_in">
    <span class="admin-badge"><i class="fa-solid fa-shield-halved"></i> Admin Access</span>
    <h1>Admin Login</h1>

    <% if (message) { %>
      <p class="error-msg"><%= message %></p>
    <% } %>

    <form action="/admin-login" method="POST">
      <div class="input-box">
        <i class="fa-solid fa-user-shield"></i>
        <input type="text" name="username" placeholder="Admin Username" required autofocus/>
      </div>
      <div class="input-box">
        <i class="fa-solid fa-lock"></i>
        <div class="pass">
          <input type="password" name="password" placeholder="Admin Password" required/>
          <i class="fa-solid fa-eye" id="togglePassword"
             onclick="togglePassword('password','togglePassword')"></i>
        </div>
      </div>
      <button type="submit" class="btn-admin">
        <i class="fa-solid fa-right-to-bracket"></i> Login as Admin
      </button>
    </form>

    <div class="user-login-link">
      Not an admin? <a href="/login">User Login →</a>
    </div>
  </div>

  <script src="/js/auth.js"></script>
</body>
</html>
