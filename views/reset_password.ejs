<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Reset Password — MyLibrary</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"/>
  <link rel="stylesheet" href="/css/auth.css"/>
</head>
<body>
  <div class="auth-split">

    <div class="auth-panel">
      <div class="auth-panel-content">
        <div class="auth-logo">
          <div class="auth-logo-icon"><i class="fa-solid fa-book-open"></i></div>
          <div>
            <span class="auth-logo-text">MyLibrary</span>
            <span class="auth-logo-sub">Digital Collection</span>
          </div>
        </div>
        <h2 class="auth-panel-headline">
          Choose a<br/><em>New</em><br/>Password.
        </h2>
        <p class="auth-panel-text">
          Create a strong password to keep your account safe. Use at least 8 characters with a mix of letters and numbers.
        </p>
      </div>
      <div class="auth-panel-footer">
        <div class="auth-stat">
          <i class="fa-solid fa-lock auth-stat-icon"></i>
          <div>
            <div class="auth-stat-num">Safe</div>
            <div class="auth-stat-label">Passwords are encrypted</div>
          </div>
        </div>
      </div>
    </div>

    <div class="auth-form-panel">
      <div class="auth-form-wrap">
        <a href="/login" class="auth-back">
          <i class="fa-solid fa-arrow-left"></i>
          Back to Login
        </a>

        <h1 class="auth-heading">Reset Password</h1>
        <p class="auth-sub">Enter your new password below.</p>

        <% if (typeof message !== 'undefined' && message) { %>
          <div class="<%= typeof type !== 'undefined' && type === 'success' ? 'msg-success' : 'msg-error' %>">
            <i class="fa-solid fa-<%= typeof type !== 'undefined' && type === 'success' ? 'circle-check' : 'circle-exclamation' %>"></i>
            <%= message %>
          </div>
        <% } %>

        <form action="/reset-password" method="POST">
          <input type="hidden" name="token" value="<%= token %>"/>
          <div class="form-group">
            <label class="form-label" for="password">New Password</label>
            <div class="input-wrap">
              <i class="fa-solid fa-lock icon-left"></i>
              <input
                class="form-input"
                type="password"
                id="password"
                name="password"
                placeholder="Enter new password"
                required
                autocomplete="new-password"
              />
              <i class="fa-solid fa-eye icon-right" id="togglePassword"
                 onclick="togglePassword('password','togglePassword')"></i>
            </div>
          </div>

          <div class="form-group">
            <label class="form-label" for="confirmPassword">Confirm New Password</label>
            <div class="input-wrap">
              <i class="fa-solid fa-lock icon-left"></i>
              <input
                class="form-input"
                type="password"
                id="confirmPassword"
                name="confirmPassword"
                placeholder="Repeat new password"
                required
                autocomplete="new-password"
              />
              <i class="fa-solid fa-eye icon-right" id="toggleConfirmPassword"
                 onclick="togglePassword('confirmPassword','toggleConfirmPassword')"></i>
            </div>
          </div>

          <button type="submit" class="btn-auth">
            <i class="fa-solid fa-key"></i>
            Update Password
          </button>
        </form>
      </div>
    </div>

  </div>

  <script src="/js/auth.js"></script>
</body>
</html>
