<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>MyLibrary — Digital Library Management System</title>
  <meta name="description" content="Discover, borrow, and manage books from a collection of over 131,000 titles. Your smart digital library, beautifully designed."/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <link rel="stylesheet" href="/css/index.css"/>
</head>
<body>

  <!-- ── Navbar ──────────────────────────────────────────────────── -->
  <header>
    <nav class="navbar">
      <a href="/" class="nav-brand">
        <div class="nav-brand-icon"><i class="fa-solid fa-book-open"></i></div>
        <div>
          <span class="nav-brand-name">MyLibrary</span>
          <span class="nav-brand-sub">Digital Collection</span>
        </div>
      </a>

      <div class="nav-links">
        <a href="/browse" class="nav-link">Browse Books</a>
        <a href="#features" class="nav-link">Features</a>
        <a href="#how-it-works" class="nav-link">How It Works</a>
      </div>

      <div class="nav-right">
        <a href="/login" class="btn-outline-nav">
          <i class="fa-solid fa-arrow-right-to-bracket"></i> Log In
        </a>
        <a href="/signup" class="btn-gold-nav">
          <i class="fa-solid fa-user-plus"></i> Get Started
        </a>
      </div>
    </nav>
  </header>

  <!-- ── Hero ────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-eyebrow">
      <i class="fa-solid fa-circle-dot"></i>
      Now Open — 131,860 Titles Available
    </div>

    <h1 class="hero-heading">
      Your World,<br/><em>Explored</em> Through<br/>Books.
    </h1>

    <p class="hero-sub">
      Discover a massive collection of books across every genre and discipline.
      Borrow instantly, track your reading, and never miss a due date —
      <strong>all in one elegant platform.</strong>
    </p>

    <div class="hero-cta">
      <a href="/browse" class="btn-hero-primary">
        <i class="fa-solid fa-magnifying-glass"></i>
        Start Browsing
      </a>
      <a href="/signup" class="btn-hero-ghost">
        Create Free Account
        <i class="fa-solid fa-arrow-right"></i>
      </a>
    </div>

    <div class="hero-stats">
      <div class="hero-stat">
        <div class="hero-stat-num">131K+</div>
        <div class="hero-stat-label">Books Available</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">100%</div>
        <div class="hero-stat-label">Digital Access</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">14 Day</div>
        <div class="hero-stat-label">Borrow Period</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">Free</div>
        <div class="hero-stat-label">To Register</div>
      </div>
    </div>
  </section>

  <!-- ── Features ────────────────────────────────────────────────── -->
  <section class="features" id="features">
    <div class="section-tag"><i class="fa-solid fa-star"></i> Why Choose Us</div>
    <h2 class="section-heading">Everything a Modern<br/>Library Should Be</h2>
    <p class="section-sub">
      From an enormous catalog to real-time availability tracking and automated reminders —
      MyLibrary gives you a seamless reading experience.
    </p>

    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon"><i class="fa-solid fa-layer-group"></i></div>
        <h3>Extensive Collection</h3>
        <p>Over 131,000 books spanning fiction, non-fiction, academic, science, history, and more — all searchable in seconds.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon"><i class="fa-solid fa-bolt"></i></div>
        <h3>Instant Borrowing</h3>
        <p>Reserve and borrow books in one click. Real-time stock tracking ensures you always know what's available.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon"><i class="fa-solid fa-bell"></i></div>
        <h3>Smart Reminders</h3>
        <p>Automatic email alerts for upcoming due dates and overdue books so you never rack up a fine.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon"><i class="fa-solid fa-chart-line"></i></div>
        <h3>Personal Dashboard</h3>
        <p>Track your issued books, return history, and fine status all from a beautifully organised personal hub.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon"><i class="fa-solid fa-shield-halved"></i></div>
        <h3>Secure & Private</h3>
        <p>Your account is protected with email verification, encrypted passwords, and secure session handling.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon"><i class="fa-solid fa-users-gear"></i></div>
        <h3>Admin Control Panel</h3>
        <p>Full administrative toolkit — manage users, books, issued records, and overdue reports from one place.</p>
      </div>
    </div>
  </section>

  <!-- ── How It Works ─────────────────────────────────────────────── -->
  <section class="how-it-works" id="how-it-works">
    <div class="section-tag" style="border-color:rgba(200,151,58,0.40);"><i class="fa-solid fa-route"></i> The Process</div>
    <h2 class="section-heading">Borrow a Book in<br/>Three Simple Steps</h2>
    <p class="section-sub">Getting started takes less than two minutes.</p>

    <div class="steps-grid">
      <div class="step-card">
        <div class="step-number">01</div>
        <h3>Create Your Account</h3>
        <p>Sign up with your email and verify it. Takes under two minutes and costs nothing.</p>
      </div>
      <div class="step-card">
        <div class="step-number">02</div>
        <h3>Search & Discover</h3>
        <p>Browse by title, author, or publisher. Our catalog of 131K+ books has something for everyone.</p>
      </div>
      <div class="step-card">
        <div class="step-number">03</div>
        <h3>Borrow Instantly</h3>
        <p>Click "Borrow", track your due date from your dashboard, and return it when you're done.</p>
      </div>
      <div class="step-card">
        <div class="step-number">04</div>
        <h3>Stay on Track</h3>
        <p>We'll send you reminders before your due date. Renew or return with a single click.</p>
      </div>
    </div>
  </section>

  <!-- ── CTA ──────────────────────────────────────────────────────── -->
  <section class="cta-section">
    <div class="section-tag"><i class="fa-solid fa-rocket"></i> Ready to Start?</div>
    <h2 class="section-heading">Join Thousands of<br/>Happy Readers Today</h2>
    <p class="section-sub">
      Create your free account and dive into a world of knowledge, stories, and discovery.
    </p>

    <div class="cta-buttons">
      <a href="/signup" class="btn-cta-primary">
        <i class="fa-solid fa-user-plus"></i>
        Create Free Account
      </a>
      <a href="/browse" class="btn-cta-ghost">
        <i class="fa-solid fa-book-open"></i>
        Browse First
      </a>
    </div>
  </section>

  <!-- ── Footer ───────────────────────────────────────────────────── -->
  <footer>
    <div class="footer-top">
      <div class="footer-brand">
        <div class="nav-brand" style="margin-bottom:14px;">
          <div class="nav-brand-icon"><i class="fa-solid fa-book-open"></i></div>
          <div>
            <span class="nav-brand-name">MyLibrary</span>
            <span class="nav-brand-sub">Digital Collection</span>
          </div>
        </div>
        <p>A smart, modern library management system for readers and institutions alike.</p>
      </div>

      <div class="footer-col">
        <h4>Library</h4>
        <ul>
          <li><a href="/browse">Browse Books</a></li>
          <li><a href="/login">My Account</a></li>
          <li><a href="/issued_books">Issued Books</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Account</h4>
        <ul>
          <li><a href="/login">Log In</a></li>
          <li><a href="/signup">Register</a></li>
          <li><a href="/forgot-password">Forgot Password</a></li>
          <li><a href="/admin-login">Admin Login</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Help</h4>
        <ul>
          <li><a href="#">How to Borrow</a></li>
          <li><a href="#">Fine Policy</a></li>
          <li><a href="#">Contact Library</a></li>
          <li><a href="#">Report an Issue</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span>&copy; 2025 MyLibrary. All rights reserved.</span>
      <div class="social-links">
        <a href="#" class="social-link" aria-label="WhatsApp"><i class="fab fa-whatsapp"></i></a>
        <a href="#" class="social-link" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
        <a href="#" class="social-link" aria-label="Twitter"><i class="fab fa-x-twitter"></i></a>
        <a href="#" class="social-link" aria-label="LinkedIn"><i class="fab fa-linkedin"></i></a>
        <a href="#" class="social-link" aria-label="Facebook"><i class="fab fa-facebook"></i></a>
      </div>
    </div>
  </footer>

</body>
</html>
