<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>MyLibrary - Digital Library Management System</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <link rel="stylesheet" href="/css/index.css"/>
  <link rel="stylesheet" href="/css/mobile-responsive.css"/>
</head>
<body>

  <header>
    <div class="navbar">
      <div class="nav-title border">
        <i class="fa-solid fa-book" aria-hidden="true"></i>
        <span>LIBRARY MANAGEMENT</span>
      </div>
      <div class="nav-right">
        <form action="/login">
          <button type="submit" class="btn border">Log in</button>
        </form>
        <form action="/signup">
          <button type="submit" class="btn border">Sign up</button>
        </form>
      </div>
    </div>
  </header>

  <section class="hero-sec">
    <h2>Welcome to MyLibrary</h2>
    <p>Discover, manage, and borrow from a massive collection of <strong>131,860 books</strong> — your digital library, redefined.</p>
    <a href="/browse">Start Browsing</a>
  </section>

  <section class="features">
    <div class="feature-box">
      <h3>Extensive Collection</h3>
      <p>Over 100+ books available across categories, authors, and genres.</p>
    </div>
    <div class="feature-box">
      <h3>Instant Borrowing</h3>
      <p>Quick book issuing and seamless returns with real-time tracking.</p>
    </div>
    <div class="feature-box">
      <h3>Personalized Dashboard</h3>
      <p>Keep track of your issued books, history, and personalized recommendations.</p>
    </div>
  </section>

  <section class="cta-section">
    <h2>Join the Digital Library Revolution</h2>
    <p>Create your account today and enjoy full access to our powerful library system.</p>
    <a href="/signup">Create an Account</a>
  </section>

  <footer>
    <p>&copy; 2025 MyLibrary. All rights reserved.</p>
    <div class="ftr">
      <a href="#" aria-label="WhatsApp"><i class="fab fa-whatsapp"></i></a>
      <a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
      <a href="#" aria-label="Twitter"><i class="fab fa-x-twitter"></i></a>
      <a href="#" aria-label="LinkedIn"><i class="fab fa-linkedin"></i></a>
      <a href="#" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
      <a href="#q" aria-label="Facebook"><i class="fab fa-facebook"></i></a>
    </div>
  </footer>

</body>
</html>
