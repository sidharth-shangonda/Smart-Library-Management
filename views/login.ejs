<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Login</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"/>
  <link rel="stylesheet" href="/css/auth.css"/>
  <link rel="stylesheet" href="/css/mobile-responsive.css"/>
</head>
<body>
  <div class="log_in">
    <h1>Login</h1>

    <% if (message) { %>
      <p class="error-msg"><%= message %></p>
    <% } %>

    <form action="/login" method="POST">
      <div class="input-box">
        <i class="fa-solid fa-user"></i>
        <input type="text" name="username" placeholder="Enter Username" required/>
      </div>
      <div class="input-box">
        <i class="fa-solid fa-lock"></i>
        <div class="pass">
          <input type="password" name="password" placeholder="Enter Password" required/>
          <i class="fa-solid fa-eye" id="togglePassword"
             onclick="togglePassword('password','togglePassword')"></i>
        </div>
      </div>
      <button type="submit" class="btn-auth">Login</button>
    </form>

    <div class="register-link register-link-top">
      <a href="/forgot-password">Forgot Password?</a>
    </div>
    <div class="register-link">
      <a href="/signup">Don't have an account? Signup</a>
    </div>
    <div class="register-link">
      <a href="/admin-login">Admin Login</a>
    </div>

    <!-- Resend Verification -->
    <div class="resend-wrap">
      <p class="resend-title">
        Didn't receive verification email?
      </p>
      <form action="/resend-verification" method="POST" class="resend-form">
        <input type="email" name="email" placeholder="Enter your email" class="resend-input"/>
        <button type="submit" class="resend-btn">
          Resend
        </button>
      </form>
    </div>
  </div>

  <script src="/js/auth.js"></script>
</body>
</html>
