PORT=8080
MONGO_URI=mongodb://localhost:27017/library
# You can generate a random string for SESSION_SECRET using online tools or libraries like crypto in Node.js
SESSION_SECRET=put_any_random_text_here
# Local URL for development. In Render set this to your live URL, e.g. https://your-service.onrender.com
APP_URL=http://localhost:8080
MAIL_USER=your_gmail@gmail.com
MAIL_PASS=your_16_char_app_password
MAIL_FROM=your_verified_sender@example.com
MAIL_TIMEOUT_MS=15000

# Optional SMTP provider settings for Render (recommended: Brevo/SendGrid/Mailgun)
# If SMTP_HOST is set, these will be used instead of Gmail defaults.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false

